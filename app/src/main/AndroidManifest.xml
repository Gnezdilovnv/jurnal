<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <application
        android:name=".App"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:requestLegacyExternalStorage="true"
        android:theme="@style/Theme.AppCompat.Light">
        
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <activity android:name=".ui.CreateReportActivity" />
        <activity android:name=".ui.ReportsListActivity" />
        <activity android:name=".ui.SettingsActivity" />
        <activity android:name=".ui.CategoriesActivity" />
        <activity android:name=".ui.VariablesActivity" />
        <activity android:name=".ui.TemplatesActivity" />
        <activity android:name=".ui.TemplateEditorActivity" />
    </application>

</manifest>
