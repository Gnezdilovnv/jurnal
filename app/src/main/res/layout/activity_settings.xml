<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Заголовок с кнопкой назад -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Назад"
                style="@style/ButtonSecondary"
                android:backgroundTint="@color/surface"
                android:textColor="@color/primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⚙️ Настройки"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center" />

        </LinearLayout>

        <!-- Режим настроек -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Режим настроек"
            style="@style/TitleStyle"
            android:layout_marginTop="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/surface"
            android:padding="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:gravity="center">

            <Button
                android:id="@+id/btnUserMode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="👤 Пользователь"
                style="@style/ButtonPrimary"
                android:backgroundTint="@color/primary"
                android:textColor="@android:color/white"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnDevMode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🛠️ Разработчик"
                style="@style/ButtonSecondary"
                android:textColor="@color/primary" />

        </LinearLayout>

        <!-- ===== РЕЖИМ ПОЛЬЗОВАТЕЛЯ ===== -->
        <LinearLayout
            android:id="@+id/userModeLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Отправка -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Отправка"
                style="@style/TitleStyle"
                android:layout_marginTop="16dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/CardStyle"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✉️ Email получателя"
                        style="@style/SubtitleStyle" />

                    <EditText
                        android:id="@+id/etEmailTo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="email@example.com"
                        android:inputType="textEmailAddress"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Сохранение -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Сохранение"
                style="@style/TitleStyle"
                android:layout_marginTop="16dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/CardStyle"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📁 Место сохранения"
                        style="@style/SubtitleStyle" />

                    <Spinner
                        android:id="@+id/spinnerSaveFolder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Формат -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Формат файла"
                style="@style/TitleStyle"
                android:layout_marginTop="16dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/CardStyle"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <Spinner
                        android:id="@+id/spinnerFormat"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Приложение -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Приложение"
                style="@style/TitleStyle"
                android:layout_marginTop="16dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/CardStyle"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:weightSum="2">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🌙 Темная тема"
                        style="@style/TitleStyle" />

                    <Switch
                        android:id="@+id/switchDarkMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- ===== РЕЖИМ РАЗРАБОТЧИКА ===== -->
        <LinearLayout
            android:id="@+id/devModeLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Дополнительные настройки для разработчика -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛠️ Дополнительные настройки"
                style="@style/TitleStyle"
                android:layout_marginTop="16dp"
                android:textColor="@color/red" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/CardStyle"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📧 Тема письма"
                        style="@style/SubtitleStyle" />

                    <EditText
                        android:id="@+id/etEmailSubject"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Отчет от {date}"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📝 Текст письма"
                        style="@style/SubtitleStyle"
                        android:layout_marginTop="12dp" />

                    <EditText
                        android:id="@+id/etEmailBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Здравствуйте! Отправляю отчет..."
                        android:minLines="3"
                        android:gravity="top"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📄 Имя файла"
                        style="@style/SubtitleStyle"
                        android:layout_marginTop="12dp" />

                    <EditText
                        android:id="@+id/etFileName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Отчет_{date}_{group}"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Данные -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Данные"
                style="@style/TitleStyle"
                android:layout_marginTop="16dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/CardStyle"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <Button
                        android:id="@+id/btnExport"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💾 Экспорт данных"
                        style="@style/ButtonSecondary"
                        android:layout_marginBottom="8dp" />

                    <Button
                        android:id="@+id/btnImport"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📥 Импорт данных"
                        style="@style/ButtonSecondary" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Управление -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Управление"
                style="@style/TitleStyle"
                android:layout_marginTop="16dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/CardStyle"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <Button
                        android:id="@+id/btnCategories"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📂 Категории"
                        style="@style/ButtonSecondary"
                        android:layout_marginBottom="8dp" />

                    <Button
                        android:id="@+id/btnVariables"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔤 Переменные"
                        style="@style/ButtonSecondary"
                        android:layout_marginBottom="8dp" />

                    <Button
                        android:id="@+id/btnTemplates"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📋 Шаблоны"
                        style="@style/ButtonSecondary" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnClearData"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🗑️ Очистить все данные"
                style="@style/ButtonPrimary"
                android:backgroundTint="@color/red"
                android:textColor="@android:color/white"
                android:layout_marginTop="16dp" />

        </LinearLayout>

        <!-- Кнопка сохранения -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💾 Сохранить настройки"
            style="@style/ButtonPrimary"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp" />

    </LinearLayout>

</ScrollView>
