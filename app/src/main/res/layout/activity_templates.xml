<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:padding="16dp">
    <Button android:id="@+id/btnBack" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="← Назад" style="@style/ButtonSecondary" />
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📋 Шаблоны" android:textSize="24sp" android:textStyle="bold" android:layout_marginTop="16dp" />
    <Button android:id="@+id/btnAddTemplate" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="➕ Добавить шаблон" style="@style/ButtonPrimary" android:layout_marginTop="16dp" />
</LinearLayout>
